# Archivist environment variables

# Data directory override (default: ~/.archivist/data/)
# ARCHIVIST_DATA_DIR=/var/lib/archivist

# Config directory override (default: ~/.archivist/)
# ARCHIVIST_CONFIG_DIR=~/.archivist

# REST API bearer token (required when binding to 0.0.0.0)
# ARCHIVIST_API_TOKEN=your-secret-token-here

# Logging level (DEBUG, INFO, WARNING, ERROR)
# ARCHIVIST_LOG_LEVEL=INFO
